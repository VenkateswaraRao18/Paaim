# ── Core ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development           # development | staging | production
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
DEBUG=false

# ── Database ───────────────────────────────────────────────────────────────────
# Development (SQLite — zero setup)
DATABASE_URL=sqlite+aiosqlite:///./paaim_dev.db
DATABASE_URL_SYNC=sqlite:///./paaim_dev.db

# Production (PostgreSQL — uncomment and fill in)
# DATABASE_URL=postgresql+asyncpg://paaim:yourpassword@localhost:5432/paaim_db
# DATABASE_URL_SYNC=postgresql://paaim:yourpassword@localhost:5432/paaim_db
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AI — Google Gemini ─────────────────────────────────────────────────────────
GEMINI_API_KEY=your-google-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash     # gemini-2.5-flash | gemini-2.5-pro | gemini-flash-latest
GEMINI_TIMEOUT=30

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_EXPIRE_MINUTES=60

# ── Rate limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=120

# ── Manufacturing connectors (leave blank to disable) ──────────────────────────
MES_HOST=
MES_PORT=8001
MES_USER=paaim
MES_PASSWORD=

CMMS_HOST=
CMMS_PORT=8002

ERP_HOST=
ERP_PORT=8003
ERP_CLIENT_ID=
ERP_CLIENT_SECRET=
ERP_API_PREFIX=/api/v1
