# PAAIM — copy to .env. Everything here is optional for a local demo.

# Optional. Without it the agents fall back to deterministic rules and say so on
# screen; detection, unit conversion, learned baselines, governance and triage
# are unaffected. With it, the reasoning is Gemini's — which is the part worth
# showing. Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Only matters if you expose this beyond your laptop. The app refuses to boot in
# production with the default.
SECRET_KEY=dev-only-not-a-production-secret
