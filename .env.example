# PAAIM Production Configuration

# Database
DATABASE_URL=postgresql://paaim:secure_password@localhost:5432/paaim_prod

# Redis
REDIS_URL=redis://localhost:6379/0

# Environment
ENVIRONMENT=production
LOG_LEVEL=INFO

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-your-key-here

# MES (Manufacturing Execution System) Connector
MES_HOST=mes.company.local
MES_PORT=8001
MES_TIMEOUT=30
MES_USER=paaim_service
MES_PASSWORD=secure_password

# CMMS (Computerized Maintenance Management) Connector
CMMS_HOST=cmms.company.local
CMMS_PORT=8002
CMMS_TIMEOUT=30

# Optional: ERP Connector (future)
# ERP_HOST=erp.company.local
# ERP_PORT=8003

# Optional: Auth
# JWT_SECRET_KEY=your-secret-key-here
# JWT_ALGORITHM=HS256
# JWT_EXPIRATION_HOURS=24
